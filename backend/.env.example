EXA_API_KEY=
AURA_USE_EXA_CACHE=true
AURA_EXA_CACHE_DIR=../aac/outputs/cache
AURA_USE_ORIEN_SEARCH=false
AURA_ORIEN_MODE=gemma_knowledge
AURA_ORIEN_AUTOSTART=true
AURA_ORIEN_START_COMMAND=node ./scripts/orien-local-search.mjs
AURA_ORIEN_SEARXNG_URL=http://localhost:8888/search
AURA_ORIEN_MAX_RESULTS=5
AURA_ORIEN_FETCH_TIMEOUT_MS=8000
AURA_ORIEN_READY_TIMEOUT_MS=20000
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=gemma-4-E2B-it
LLM_AUTOSTART=true
LLM_USE_FOR_CARDS=true
LLM_USE_FOR_EVALUATION=false
LLM_PROBE_ON_HEALTH=false
LLM_READY_TIMEOUT_MS=45000
LLM_START_COMMAND=litert-lm serve --api gemini --port 8080
LLM_MODEL_REPO=litert-community/gemma-4-E2B-it-litert-lm
LLM_LIT_MODEL_NAME=gemma-4-E2B-it
LLM_MODEL_PATH=./models/gemma-4-E2B-it-litert-lm
BACKEND_PORT=3101
DB_PATH=./aura.db
DEFAULT_PROFILE_ID=profile_001
