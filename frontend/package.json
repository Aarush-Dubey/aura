{
  "name": "aura-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "electron": "electron .",
    "desktop": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@types/katex": "^0.16.8",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.2",
    "katex": "^0.16.45",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2"
  }
}
